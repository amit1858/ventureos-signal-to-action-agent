# Signal-to-Action Agent Environment Variables
# Copy this file to .env and customize values as needed

# ============================================================================
# Model Provider Configuration
# ============================================================================
# The deterministic business engine is ALWAYS the source of truth for ranking,
# scoring and actions. The model provider only generates the executive *narrative*
# (the human-readable "why"). Swapping providers never changes the numbers.
#
# Provider strategy (single switch -- MODEL_PROVIDER):
#   mock     -> deterministic placeholder narrative, no API key. (DEFAULT, wired)
#   nvidia   -> NVIDIA NIM / Nemotron narrative.   (stub adapter present; aliases:
#               nvidia | nvidia-nim | nim | nemotron)
#   openai   -> OpenAI narrative provider.         (PLACEHOLDER -- not wired yet;
#               setting this today safely falls back to the mock adapter)
#   claude   -> Anthropic Claude narrative provider. (PLACEHOLDER -- not wired yet;
#               aliases: claude | anthropic; falls back to mock today)
#
# Governance, evidence, confidence and human approval remain deterministic and
# auditable regardless of which provider is selected.
MODEL_PROVIDER=mock

# ============================================================================
# OpenAI / Anthropic Configuration (PLACEHOLDERS -- not wired yet)
# ============================================================================
# Reserved for the future OpenAI and Anthropic Claude narrative providers.
# Selecting MODEL_PROVIDER=openai or =claude today safely falls back to the mock
# adapter (a warning is logged). Leave blank for the demo.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================================================
# NVIDIA NIM / Nemotron Configuration (only needed when MODEL_PROVIDER=nvidia)
# ============================================================================
# NVIDIA API key for NIM access (obtain from build.nvidia.com or hackathon organizers)
NVIDIA_API_KEY=

# NVIDIA NIM base URL (OpenAI-compatible endpoint)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# NVIDIA model identifier (e.g., Nemotron-4 340B Instruct)
NVIDIA_NIM_MODEL=nvidia/nemotron-4-340b-instruct

# Request timeout in seconds
NVIDIA_NIM_TIMEOUT=30

# ============================================================================
# Backend API Configuration
# ============================================================================
# SQLite database path for decision ledger persistence
# (relative to services/api/ or absolute path)
DB_PATH=signal_to_action.db

# CORS origins (comma-separated or * for all)
CORS_ORIGINS=*

# Log level for the structured application logger (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# ============================================================================
# HubSpot Test CRM Integration (optional connector)
# ============================================================================
# The agent works fully on synthetic local data with all of these unset.
# Enable this only to demo a real HubSpot *test/sandbox* portal. Never point it
# at a production portal or real customer data, and never commit a real token.
#
# Master switch. When false, the connector is advertised in the UI but inert.
HUBSPOT_ENABLED=false

# HubSpot private-app access token (Bearer). Obtain from a HubSpot *test* account:
# Settings -> Integrations -> Private Apps -> Create. Leave blank to keep disabled.
HUBSPOT_ACCESS_TOKEN=

# Optional portal id, shown in the UI status card and write-back links.
HUBSPOT_PORTAL_ID=

# Max companies to pull per sync.
HUBSPOT_SYNC_LIMIT=100

# Auto-sync HubSpot at backend startup (recommended for hosted demos).
# When true AND the connector is enabled+configured, the backend performs one
# best-effort, read-only company sync in the background at boot, so a cold-started
# host (e.g. Render free tier, which resets to synthetic on every restart) serves
# live CRM data without a manual sync. It never blocks startup, never seeds, never
# writes back, and falls back to synthetic data on any failure. Default: false.
HUBSPOT_AUTO_SYNC_ON_STARTUP=true

# Background refresh interval in seconds. 0 = OFF (default).
# When > 0 AND HubSpot is enabled+configured, a single background thread re-syncs
# companies on this cadence so a long-running backend never serves stale data.
# On any refresh failure it keeps the last-good data (never downgrades a live
# demo) and it respects a manual switch to synthetic. Recommended for hosted
# demos: 900 (15 minutes). Keep it >= 60 to avoid HubSpot rate limits.
HUBSPOT_REFRESH_INTERVAL_SECONDS=0

# Second safety gate for WRITE operations (seed + task/note write-back).
# Must be true AND HUBSPOT_ENABLED=true before anything is written to HubSpot.
HUBSPOT_WRITEBACK_ENABLED=false

# Custom-property namespace + API base (rarely need changing).
HUBSPOT_PROPERTY_PREFIX=s2a_
HUBSPOT_BASE_URL=https://api.hubapi.com
HUBSPOT_TIMEOUT=30


# ============================================================================
# Outside-In External Signals (optional enrichment layer)
# ============================================================================
# Additive, supporting-context layer that enriches an account with PUBLIC
# external context (company news, market trends, funding, layoffs, leadership
# changes, regulatory, competitive/macro pressure).
#
# IMPORTANT: external signals are NOT the source of truth. They never change
# ranking, scoring, governance, or CRM writeback. They are cited, caveated,
# supporting context only, fetched on-demand per account and cached. If the
# provider is unavailable or unconfigured, the app falls back to deterministic
# mock signals and NEVER fails. Default OFF for V1 safety.
#
# Master switch. When false, the external-signals endpoints return empty results
# with a note and the UI section stays hidden. The product behaves exactly as V1.
EXTERNAL_SIGNALS_ENABLED=false

# Provider strategy (single switch -- EXTERNAL_SIGNALS_PROVIDER):
#   mock     -> deterministic, curated demo context, no API key. (DEFAULT, wired)
#   serper   -> live Google News via serper.dev. Requires SERPER_API_KEY; on any
#               error or missing key it safely falls back to the mock provider.
EXTERNAL_SIGNALS_PROVIDER=mock

# serper.dev API key (only needed when EXTERNAL_SIGNALS_PROVIDER=serper).
# Obtain from https://serper.dev. Leave blank to use the mock provider.
SERPER_API_KEY=

# Cache freshness. External search is cached by company_name+industry+region so
# pages don't trigger repeated lookups. For the demo, once-per-day is plenty.
EXTERNAL_SIGNALS_CACHE_TTL_MINUTES=1440

# Max accounts enriched by POST /api/external-signals/refresh (priority accounts
# only). Keeps refreshes bounded and provider usage predictable.
EXTERNAL_SIGNALS_REFRESH_LIMIT=10


# ============================================================================
# Frontend Configuration (Next.js)
# ============================================================================
# Backend API base URL for the frontend to call
# Set this in apps/web/.env.local if you want to override
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
