# Base URL of the FastAPI backend. The frontend reads this at build/runtime.
# Copy this file to .env.local and adjust if your API runs elsewhere.
# In production (e.g. Vercel) set this to your deployed backend URL
# (Render / Railway / Azure App Service); do not rely on localhost.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: display name for the Executive Morning Brief greeting
# ("Good Morning <First Name> 👋"). Leave unset to show the greeting with no
# name. This is never hardcoded in the app; it is resolved at runtime from a
# local-only override (localStorage "s2a_display_name") or this build-time env.
# NEXT_PUBLIC_USER_NAME=
